---
import { Image } from 'astro:assets';

// Grab every photo in src/assets/photos and let Astro optimize each one
// (resized + converted to webp at build time).
const modules = import.meta.glob(
  '../assets/photos/*.{JPG,jpg,jpeg,JPEG,png,PNG,webp,WEBP}',
  { eager: true }
);
const photos = Object.values(modules).map((m: any) => m.default);

// Shuffle (Fisher–Yates), then split in half: one half per column.
const shuffled = [...photos];
for (let i = shuffled.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
}
const mid = Math.ceil(shuffled.length / 2);

// Duration scales with the number of photos so the scroll speed stays
// constant (and slow) regardless of how many end up in each column.
const SECONDS_PER_PHOTO = 5;

const columns = [
  { side: 'left', dir: 'down', items: shuffled.slice(0, mid) },
  { side: 'right', dir: 'up', items: shuffled.slice(mid) },
];

// Intrinsic width Astro renders each photo at (columns display them smaller,
// so this keeps them crisp on high-DPI screens).
const RENDER_WIDTH = 440;
---

<div class="photo-cols" aria-hidden="true">
  {
    columns.map((col) => (
      <aside
        class={`photo-col photo-col--${col.side}`}
        style={`--dur:${Math.max(col.items.length, 1) * SECONDS_PER_PHOTO}s`}
      >
        {/* The list is rendered twice so the vertical loop is seamless. */}
        <div class={`track track--${col.dir}`}>
          {[...col.items, ...col.items].map((img) => (
            <figure class="photo">
              <Image src={img} alt="" width={RENDER_WIDTH} loading="lazy" decoding="async" />
            </figure>
          ))}
        </div>
      </aside>
    ))
  }
</div>

<style>
  /* Desktop: the wrapper generates no box; each column is fixed to a gutter. */
  .photo-cols {
    display: contents;
  }

  .photo-col {
    position: fixed;
    top: 0;
    bottom: 0;
    width: min(300px, calc((100vw - var(--max-width)) / 2 - 2rem));
    overflow: hidden;
    z-index: 1;
    pointer-events: auto;
    /* Fade the top & bottom edges so photos dissolve into the background. */
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 7%,
      #000 93%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 7%,
      #000 93%,
      transparent 100%
    );
  }
  .photo-col--left {
    left: 0;
  }
  .photo-col--right {
    right: 0;
  }

  .track {
    display: flex;
    flex-direction: column;
    padding-inline: 0.9rem;
    will-change: transform;
  }
  .track--up {
    animation: scroll-up var(--dur) linear infinite;
  }
  .track--down {
    animation: scroll-down var(--dur) linear infinite;
  }

  /* Stop the whole column the instant a photo is hovered. */
  .track:has(.photo:hover) {
    animation-play-state: paused;
  }

  .photo {
    position: relative;
    margin: 0 0 0.9rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    line-height: 0;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }
  .photo :global(img) {
    width: 100%;
    height: auto;
    display: block;
    filter: blur(3px) saturate(0.92);
    opacity: 0.82;
    transition: filter 0.35s ease, opacity 0.35s ease;
  }

  /* Lift + unblur the hovered photo. */
  .photo:hover {
    transform: scale(1.04);
    z-index: 2;
    box-shadow: 0 14px 44px rgba(0, 0, 0, 0.45);
  }
  .photo:hover :global(img) {
    filter: none;
    opacity: 1;
  }

  @keyframes scroll-up {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }
  @keyframes scroll-down {
    from {
      transform: translateY(-50%);
    }
    to {
      transform: translateY(0);
    }
  }

  /* Mobile: no side gutters to fill, so lay the two carousels side by side and
     let them fill the bottom of the (locked, no-scroll) screen — left column
     scrolling down, right column scrolling up. */
  @media (max-width: 1080px) {
    .photo-cols {
      display: flex;
      flex-direction: row;
      gap: 0.5rem;
      /* basis 0 (not auto) so the tall stacked-image content doesn't inflate
         the flex base size and steal height from the hero above. */
      flex: 1 1 0;
      min-height: 0;
      width: 100%;
      padding: 0 0.5rem 0.5rem;
      overflow: hidden;
    }
    .photo-col {
      position: static;
      width: auto;
      height: 100%;
      flex: 1 1 0;
      min-height: 0;
    }
    .track {
      padding-inline: 0.35rem;
    }
    .photo {
      margin-bottom: 0.5rem;
    }
  }
</style>

<script>
  // The frontmatter shuffle above runs at build time, so the baked-in HTML
  // shows the same order to every visitor (and acts as a no-JS fallback).
  // Reshuffle on the client so the arrangement is randomized on each load.
  const SECONDS_PER_PHOTO = 5;

  function shuffle(arr: unknown[]) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function randomizePhotos() {
    const cols = document.querySelector('.photo-cols');
    if (!cols) return;
    const tracks = cols.querySelectorAll<HTMLElement>('.track');
    if (tracks.length < 2) return;

    // Each track renders its photos twice for the seamless loop, so gather the
    // unique figures across both columns (deduped by image src).
    const seen = new Set<string>();
    const figures: HTMLElement[] = [];
    tracks.forEach((track) => {
      track.querySelectorAll<HTMLElement>('.photo').forEach((fig) => {
        const src = fig.querySelector('img')?.getAttribute('src') ?? '';
        if (seen.has(src)) return;
        seen.add(src);
        figures.push(fig);
      });
    });

    shuffle(figures);
    const mid = Math.ceil(figures.length / 2);
    const halves = [figures.slice(0, mid), figures.slice(mid)];

    tracks.forEach((track, i) => {
      const items = halves[i] ?? [];
      track.replaceChildren();
      // Render each half twice so the vertical loop stays seamless.
      [...items, ...items].forEach((fig) => track.appendChild(fig.cloneNode(true)));
      // Rescale the animation duration so scroll speed stays constant.
      const col = track.closest<HTMLElement>('.photo-col');
      col?.style.setProperty('--dur', `${Math.max(items.length, 1) * SECONDS_PER_PHOTO}s`);
    });
  }

  randomizePhotos();
</script>
