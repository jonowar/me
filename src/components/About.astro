---
import { ABOUT, SKILLS } from '../consts';
---

<section class="section about" id="about">
  <div class="container">
    <span class="eyebrow">// about</span>
    <h2 class="section-title">A little about me</h2>

    <div class="about-body">
      {ABOUT.map((para) => <p>{para}</p>)}
    </div>

    {
      SKILLS.length > 0 && (
        <div class="skills">
          <h3 class="skills-title">Tools I reach for</h3>
          <ul class="skills-list">
            {SKILLS.map((s) => (
              <li class="pill">{s}</li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</section>

<style>
  .about {
    border-top: 1px solid var(--border);
  }

  .about-body p {
    color: var(--text-muted);
    font-size: 1.08rem;
    line-height: 1.75;
    max-width: 60ch;
  }
  .about-body p + p {
    margin-top: 1.1rem;
  }

  .skills {
    margin-top: 2.5rem;
  }

  .skills-title {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--text-faint);
    text-transform: lowercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.9rem;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }
</style>
