---
import { SITE, PROJECTS } from '../consts';

// Split the title on the dot so we can accent the "." like a logo.
const [before, ...rest] = SITE.title.split('.');
const after = rest.join('.');
---

<section class="hero" id="top">
  <div class="container">
    <h1 class="display">
      {before}<span class="dot">.</span>{after}
    </h1>

    <ul class="projects">
      {
        PROJECTS.map((p) => (
          <li class="project">
            <span class="marker" aria-hidden="true">&gt;</span>
            {p.href ? (
              <a
                href={p.href}
                target={p.href.startsWith('http') ? '_blank' : undefined}
                rel={
                  p.href.startsWith('http') ? 'noopener noreferrer' : undefined
                }
              >
                {p.name}
              </a>
            ) : (
              <span>{p.name}</span>
            )}
            {p.description && <span class="desc"> — {p.description}</span>}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(2rem, 8vw, 5rem);
    padding-bottom: clamp(3rem, 9vw, 6rem);
  }

  .display {
    font-family: var(--font-display);
    font-weight: 400;
    /* 13vw keeps all 14 monospace characters on a single line from small
       phones up to where the column hits its max width (then the 6.5rem cap
       takes over). Verified to leave margin at every width via CDP. */
    font-size: clamp(2.25rem, 13vw, 6.5rem);
    line-height: 0.92;
    letter-spacing: 0;
    white-space: nowrap;
    margin-bottom: clamp(1.75rem, 5vw, 3rem);
    /* subtle CRT-style glow, kept faint so it reads in both themes */
    text-shadow: 0 0 22px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .dot {
    color: var(--accent);
  }

  .projects {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    line-height: 1.2;
  }

  .project {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .marker {
    color: var(--accent);
  }

  .project a {
    color: var(--text);
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .project a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .desc {
    color: var(--text-muted);
  }
</style>
