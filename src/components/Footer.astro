---
import { SITE, SOCIALS } from '../consts';
---

<footer class="footer">
  <div class="container container--wide footer-inner">
    <p class="footer-name">© {SITE.name}</p>
    <nav class="footer-links" aria-label="Footer">
      {
        SOCIALS.map((s) => <a href={s.href}>{s.label}</a>)
      }
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-block: 2rem;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-name {
    color: var(--text-faint);
    font-size: 1.05rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }
  .footer-links a {
    color: var(--text-muted);
    font-size: 1.05rem;
  }
  .footer-links a:hover {
    color: var(--text);
  }

  @media (max-width: 1080px) {
    .footer {
      padding-block: 0.9rem;
    }
  }
</style>
